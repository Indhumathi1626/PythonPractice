a = int(input("Enter a number:"))
if a%2 == 0 and a%4 == 0:
    print(f"The number {a} is even and multiple of four")
elif a%2 == 0 and a/4 !=0:
    print(f" The number {a} is only an even number")
elif a%2 != 0:
    print(f" The number {a} is a odd number") 
